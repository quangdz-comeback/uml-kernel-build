# Kernel config fragment: enable container support (Docker/Podman/LXC) on UML.
#
# Applied via `scripts/kconfig/merge_config.sh` on top of the base defconfig.
# Favour cgroup v2 (unified hierarchy) — Docker >= 20.10 and Podman default to v2;
# the kernel exposes v2 by simply mounting `cgroup2` (no Kconfig switch needed,
# only the controllers below). cgroup v1 stays available as fallback.
#
# Runtime notes for UML specifically:
#   - VETH/BRIDGE work *inside* the guest for container<->container traffic.
#     There is no host TAP driver; egress to the host uses UML's own
#     vector/slirp transport (separate from the in-guest bridge).
#   - No loop device (`/dev/loop*`), so Docker loopback/devicemapper storage
#     is unavailable — use overlay2 (enabled) on a raw ubd backing file.
#
# === Namespaces (isolation primitives) ===
CONFIG_NAMESPACES=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_IPC_NS=y
CONFIG_UTS_NS=y
CONFIG_CGROUP_NS=y

# === Cgroup v2 controllers ===
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_RDMA=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_PERF=y
CONFIG_CGROUP_BPF=y
CONFIG_CGROUP_WRITEBACK=y
CONFIG_CGROUP_NET_CLASSID=y
CONFIG_CGROUP_NET_PRIO=y
CONFIG_CGROUP_MISC=y
CONFIG_SOCK_CGROUP_DATA=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y
CONFIG_BLK_DEV_THROTTLING=y

# === Seccomp — Docker/Podman hard-require this ===
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_SECCOMP_CACHE=y

# === Storage ===
CONFIG_OVERLAY_FS=y
CONFIG_FUSE_FS=y
CONFIG_FHANDLE=y
CONFIG_POSIX_MQUEUE=y
CONFIG_FANOTIFY=y

# === Networking: container bridge + NAT + iptables ===
CONFIG_VETH=y
CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NETFILTER_XTABLES=y
CONFIG_NETFILTER_NETLINK=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y
CONFIG_NF_DEFRAG_IPV4=y
CONFIG_NF_DEFRAG_IPV6=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_MANGLE=y
CONFIG_NETFILTER_XT_TARGET_MASQUERADE=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NETFILTER_XT_MATCH_COMMENT=y
CONFIG_NETFILTER_XT_MATCH_MULTIPORT=y
CONFIG_IP_VS=y
CONFIG_IP_SET=y

# === BPF / keys / security ===
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_KEYS=y
CONFIG_SECURITY=y
CONFIG_SECURITYFS=y
CONFIG_SECURITY_NETWORK=y
CONFIG_SECURITY_YAMA=y
